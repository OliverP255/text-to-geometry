# Copy to ".env" in the repo root (gitignored). The scene server loads it when python-dotenv is installed.
#
# --- Scene server (existing) ---
# T2G_MODEL_ID=

# --- Print backend (Neon Postgres) ---
# Connection string from Neon (use sslmode=require in URL if required by host).
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT for /api/auth/* and user print routes (use a long random secret in production).
JWT_SECRET=change-me
JWT_EXPIRY_HOURS=168

# Shared secret for admin API + /admin/print-jobs UI (X-Print-Admin-Token header).
PRINT_ADMIN_TOKEN=change-me-admin

# Discord incoming webhook URL for new print job notifications (optional).
DISCORD_PRINT_WEBHOOK_URL=

# Public base URL for links in Discord messages (no trailing slash).
PUBLIC_APP_URL=http://127.0.0.1:5001

# Where generated STL files are stored server-side (default: repo data/print_uploads).
PRINT_UPLOAD_DIR=

# Printer / validation limits (optional; defaults shown).
PRINT_MAX_MM=250,210,210
PRINT_MAX_TRIANGLES=500000
PRINT_MIN_WALL_MM=0.4
