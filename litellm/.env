# LiteLLM proxy: python-dotenv (used by the `litellm` CLI) walks up from cwd and loads
# the first `.env` it finds. Without this file, it loads ../.env and picks up DATABASE_URL
# for the main app — the proxy then requires Prisma and fails startup without `prisma` installed.
# This file intentionally does not set DATABASE_URL; routing is from config.yaml only.

# LiteLLM → Vertex (GLM): only this process uses GCP. Claude Code does not read this;
# it talks to LiteLLM via ~/.claude/settings.json (ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN).
VERTEXAI_PROJECT=oliver-pryce-490012
